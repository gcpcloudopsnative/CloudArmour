data":{"id":"7goqgMw-GXuP"}},{"cell_type":"code","source":["from tensorflow.keras.models import Sequential\n","from tensorflow.keras.layers import (\n","    Conv1D, MaxPooling1D,\n","    Dense, Dropout, BatchNormalization, Bidirectional, LSTM\n",")\n","from tensorflow.keras.utils import to_categorical\n","\n","# One-hot encoding\n","y_train_cat = to_categorical(y_train, num_classes)\n","y_test_cat  = to_categorical(y_test, num_classes)\n","\n","cnn_bilstm = Sequential()\n","\n","# CNN block\n","cnn_bilstm.add(Conv1D(\n","    filters=64,\n","    kernel_size=3,\n","    activation=\"relu\",\n","    padding=\"same\",\n","    input_shape=(TIMESTEPS, num_features)\n","))\n","cnn_bilstm.add(BatchNormalization())\n","cnn_bilstm.add(MaxPooling1D(pool_size=1))\n","\n","# BiLSTM block\n","cnn_bilstm.add(Bidirectional(\n","    LSTM(64, return_sequences=False)\n","))\n","cnn_bilstm.add(Dropout(0.3))\n","\n","# Fully connected\n","cnn_bilstm.add(Dense(128, activation=\"relu\"))\n","cnn_bilstm.add(Dropout(0.3))\n","cnn_bilstm.add(Dense(num_classes, activation=\"softmax\"))\n","\n","cnn_bilstm.compile(\n","    optimizer=\"adam\",\n","    loss=\"categorical_crossentropy\",\n","    metrics=[\"accuracy\"]\n",")\n","\n","cnn_bilstm.summary()\n"],"metadata":{"id":"74D8bC9SGXV1"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["history_bilstm = cnn_bilstm.fit(\n","    X_train_seq,\n","    y_train_cat,\n","    epochs=20,\n","    batch_size=512,\n","    validation_split=0.2,\n","    verbose=1\n",")\n"],"metadata":{"id":"_7foqKF_GkYW"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from sklearn.metrics import classification_report\n","\n","bilstm_preds = np.argmax(cnn_bilstm.predict(X_test_seq), axis=1)\n","\n","print(\"CNN + BiLSTM Results\")\n","print(classification_report(\n","    y_test,\n","    bilstm_preds,\n","    target_names=label_encoder.classes_\n","))\n"],"metadata":{"id":"ay6NXYKlGpZY"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def predict_single_flow_cnn_bilstm(flow_dict):\n","    flow = np.array(\n","        [flow_dict[f] for f in feature_names],\n","        dtype=np.float32\n","    ).reshape(1, -1)\n","\n","    flow_scaled = scaler.transform(flow)\n","    flow_seq = flow_scaled.reshape((1, TIMESTEPS, num_features))\n","\n","    probs = cnn_bilstm.predict(flow_seq, verbose=0)\n","    pred_class = np.argmax(probs, axis=1)[0]\n","    pred_label = label_encoder.inverse_transform([pred_class])[0]\n","\n","    return pred_label, probs\n"],"metadata":{"id":"K4-fJciKGtjC"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import pickle\n","\n","# Define the filename\n","filename = '/content/drive/MyDrive/DDoSDetect/CNN_BiLSTM.pkl'\n","\n","# Open the file in 'write binary' mode ('wb') and save the model\n","with open(filename, 'wb') as file:\n","    pickle.dump(cnn_bilstm, file)\n","\n","print(f\"Model successfully saved as {filename}\")"],"metadata":{"id":"YW-Q05R2brpK"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["**CNN + BiLSTM + Attention**"],"metadata":{"id":"3U-nqneLG5FN"}},{"cell_type":"code","source":["from tensorflow.keras.layers import Layer\n","import tensorflow as tf\n","\n","class Attention(Layer):\n","    def __init__(self):\n","        super().__init__()\n","\n","    def call(self, inputs):\n","        score = tf.nn.softmax(tf.reduce_mean(inputs, axis=2), axis=1)\n","        score = tf.expand_dims(score, axis=2)\n","        context = tf.reduce_sum(inputs * score, axis=1)\n","        return context\n"],"metadata":{"id":"DOC1Fe0qG_Pw"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from tensorflow.keras.models import Model\n","from tensorflow.keras.layers import Input\n","\n","inputs = Input(shape=(TIMESTEPS, num_features))\n","\n","# CNN block\n","x = Conv1D(64, 3, padding=\"same\", activation=\"relu\")(inputs)\n","x = BatchNormalization()(x)\n","x = MaxPooling1D(pool_size=1)(x)\n","\n","# BiLSTM block\n","x = Bidirectional(LSTM(64, return_sequences=True))(x)\n","x = Dropout(0.3)(x)\n","\n","# Attention block\n","x = Attention()(x)\n","\n","# Fully connected\n","x = Dense(128, activation=\"relu\")(x)\n","x = Dropout(0.3)(x)\n","outputs = Dense(num_classes, activation=\"softmax\")(x)\n","\n","cnn_bilstm_att = Model(inputs, outputs)\n","\n","cnn_bilstm_att.compile(\n","    optimizer=\"adam\",\n","    loss=\"categorical_crossentropy\",\n","    metrics=[\"accuracy\"]\n",")\n","\n","cnn_bilstm_att.summary()\n","\n","history_att = cnn_bilstm_att.fit(\n","    X_train_seq,\n","    y_train_cat,\n","    epochs=20,\n","    batch_size=512,\n","    validation_split=0.2,\n","    verbose=1\n",")\n"],"metadata":{"id":"4mVDqo1KG-30"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["att_preds = np.argmax(cnn_bilstm_att.predict(X_test_seq), axis=1)\n","\n","print(\"CNN + BiLSTM + Attention Results\")\n","print(classification_report(\n","    y_test,\n","    att_preds,\n","    target_names=label_encoder.classes_\n","))\n"],"metadata":{"id":"RdZzf6o4G-bu"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["import pickle\n","\n","# Define the filename\n","filename = '/content/drive/MyDrive/DDoSDetect/CNN_BiLSTM_Attention.pkl'\n","\n","# Open the file in 'write binary' mode ('wb') and save the model\n","with open(filename, 'wb') as file:\n","    pickle.dump(cnn_bilstm_att, file)\n","\n","print(f\"Model successfully saved as {filename}\")"],"metadata":{"id":"XFCc2y9hbwMK"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def predict_single_flow_cnn_bilstm_att(flow_dict):\n","    flow = np.array(\n","        [flow_dict[f] for f in feature_names],\n","        dtype=np.float32\n","    ).reshape(1, -1)\n","\n","    flow_scaled = scaler.transform(flow)\n","    flow_seq = flow_scaled.reshape((1, TIMESTEPS, num_features))\n","\n","    probs = cnn_bilstm_att.predict(flow_seq, verbose=0)\n","    pred_class = np.argmax(probs, axis=1)[0]\n","